  "datafy": {
    "prefix": "datafy",
    "body": [
      "clojure.datafy/datafy ${1:data}"
    ]
  },
  "def": {
    "prefix": "def",
    "body": [
      "def ${1:a} ${2:b}"
    ]
  },
  "def-dynamic": {
    "prefix": "def-dynamic",
    "body": [
      "def ^:dynamic ${1:a} ${2:b}"
    ]
  },
  "defmethod": {
    "prefix": "defmethod",
    "body": [
      "defmethod ${1:name} ${2:tag}",
      "\t\"${3:doc}\"",
      "\t[${4:params}]",
      "\t${5:body}"
    ]
  },
  "defmulti": {
    "prefix": "defmulti",
    "body": [
      "defmulti ${1:name} ${2:dispatch-fn}"
    ]
  },
  "defn": {
    "prefix": "defn",
    "body": [
      "defn ${1:name}",
      "\t\"${2:doc}\"",
      "\t[${3:params}]",
      "\t${4:body}"
    ]
  },
  "defonce": {
    "prefix": "defonce",
    "body": [
      "defonce ${1:a} ${2:b}"
    ]
  },
  "defonce-dynamic": {
    "prefix": "defonce-dynamic",
    "body": [
      "defonce ^:dynamic ${1:a} ${2:b}"
    ]
  },
  "defrecord": {
    "prefix": "defrecord",
    "body": [
      "defrecord ${1:name} [{$2:props}]"
    ]
  },
  "fields": {
    "prefix": "flds",
    "body": [
      "{:flds [${1:f}]}"
    ]
  },
  "fields-as": {
    "prefix": "flds-as",
    "body": [
      "{:flds [${1:f}] :as ${2:as}}"
    ]
  },
  "fn": {
    "prefix": "fn",
    "body": [
      "fn [${1:params}]",
      "\t${2:body}"
    ]
  },
  "for": {
    "prefix": "for",
    "body": [
      "for [${1:i} ${2:col}]",
      "\t${3:body}"
    ]
  },
  "for-when": {
    "prefix": "for-when",
    "body": [
      "for [${1:i} ${2:col} :when (${3:f} ${1:i})]",
      "\t${4:body}"
    ]
  },
  "for-while": {
    "prefix": "for-while",
    "body": [
      "for [${1:i} ${2:col} :while (${3:f} ${1:i})]",
      "\t${4:body}"
    ]
  },
  "if": {
    "prefix": "if",
    "body": [
      "if ${1:test} ${2:then-body} ${3:else-body}"
    ]
  },
  "if-eq": {
    "prefix": "if-eq",
    "body": [
      "if (= ${1:a} ${2:b})",
      "\t${3:then-body}",
      "\t${4:else-body}"
    ]
  },
  "if-let": {
    "prefix": "if-let",
    "body": [
      "if-let [${1:a} ${2:b}]",
      "\t${3:then-body}",
      "\t${4:else-body}"
    ]
  },
  "if-ne": {
    "prefix": "if-ne",
    "body": [
      "if (not= ${1:a} ${2:b})",
      "\t${3:then-body}",
      "\t${4:else-body}"
    ]
  },
  "if-not": {
    "prefix": "if-not",
    "body": [
      "if-not ${1:test} ${2:then-body} ${3:else-body}"
    ]
  },
  "if-some": {
    "prefix": "if-some",
    "body": [
      "if-some [${1:a} ${2:b}]",
      "\t${3:then-body}",
      "\t${4:else-body}"
    ]
  },
  "ig-repl": {
    "prefix": "ig-repl",
    "body": [
      "(ns user",
      "  (:require [integrant.repl :as ig-repl]",
      "            [${1:main-ns} :as system]))",
      "",
      "(ig-repl/set-prep! (fn [] system/config))",
      "",
      "(def go ig-repl/go)",
      "(def halt ig-repl/halt)",
      "(def reset ig-repl/reset)",
      "(def reset-all ig-repl/reset-all)",
      "",
      "(comment",
      "  (go)",
      "  (halt)",
      "  (reset)",
      "  (reset-all))"
    ]
  },
  "json-cheshire": {
    "prefix": "json-cheshire",
    "body": [
      "cheshire.core"
    ]
  },
  "keys": {
    "prefix": "keys",
    "body": [
      "{:keys [${1:k}]}"
    ]
  },
  "keys-as": {
    "prefix": "keys-as",
    "body": [
      "{:keys [${1:k}] :as ${2:as}}"
    ]
  },
  "let": {
    "prefix": "let",
    "body": [
      "let [${1:a} ${2:b}]",
      "\t${3:body}"
    ]
  },
  "pprint": {
    "prefix": "pp",
    "body": [
      "clojure.pprint/pprint ${1:v}"
    ]
  },
  "println": {
    "prefix": "p",
    "body": [
      "println ${1:v}"
    ]
  },
  "repl": {
    "prefix": "repl",
    "body": [
      "(comment",
      "  (use '[clojure.repl])",
      "  ;; apropos",
      "  (->> \"symbol\"",
      "       (apropos)",
      "       (filter (fn [x]",
      "                 (or",
      "                  (clojure.string/starts-with? x \"clojure\")",
      "                  true))))",
      "  ;; doc",
      "  (doc with-open)",
      "  ;; source",
      "  (source with-open)",
      "  ;; dir",
      "  (->>",
      "   (dir clojure.string)",
      "   (with-out-str)",
      "   (clojure.string/split-lines)",
      "   (map symbol))",
      "  ;; all ns",
      "  (->>",
      "   (all-ns)",
      "   (map str)",
      "   sort))"
    ]
  },
  "ring-request-gen": {
    "prefix": "ring-request-gen",
    "body": [
      "{:request-method ${1::get}",
      "\t:uri ${2:/foo}",
      "\t:query-params {${3}}",
      "\t:headers {${4}}",
      "\t:form-params {${5}}",
      "}"
    ]
  },
  "sleep": {
    "prefix": "sleep",
    "body": [
      "Thread/sleep ${1:seconds}"
    ]
  },
  "when": {
    "prefix": "when",
    "body": [
      "when ${1:a} ${2:body}"
    ]
  },
  "when-eq": {
    "prefix": "when-eq",
    "body": [
      "when (= ${1:a} ${2:b})",
      "\t${3:body}"
    ]
  },
  "when-first": {
    "prefix": "when-first",
    "body": [
      "when-first [${1:a} ${2:b}]",
      "\t${3:body}"
    ]
  },
  "when-let": {
    "prefix": "when-let",
    "body": [
      "when-let [${1:a} ${2:b}]",
      "\t${3:body}"
    ]
  },
  "when-ne": {
    "prefix": "when-ne",
    "body": [
      "when (not= ${1:a} ${2:b})",
      "\t${3:body}"
    ]
  },
  "when-not": {
    "prefix": "when-not",
    "body": [
      "when-not ${1:a} ${2:body}"
    ]
  },
  "when-some": {
    "prefix": "when-some",
    "body": [
      "when-some [${1:a} ${2:b}]",
      "\t${3:body}"
    ]
  }
