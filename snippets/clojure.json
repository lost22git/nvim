  "assert-eq": {
    "prefix": "assert-eq",
    "body": [
      "assert (= ${1:expect}",
      "\t${2:body})"
    ]
  },
  "assert-false": {
    "prefix": "assert-false",
    "body": [
      "assert (not ${1:false-body})"
    ]
  },
  "assert-ne": {
    "prefix": "assert-ne",
    "body": [
      "assert (not= ${1:expect}",
      "\t${2:body})"
    ]
  },
  "assert-nil": {
    "prefix": "assert-nil",
    "body": [
      "assert (nil? ${1:body})"
    ]
  },
  "assert-not-nil": {
    "prefix": "assert-not-nil",
    "body": [
      "assert (not (nil? ${1:body}))"
    ]
  },
  "assert-true": {
    "prefix": "assert-true",
    "body": [
      "assert ${1:true-body}"
    ]
  },
  "bb-add-deps": {
    "prefix": "bb-add-deps",
    "body": [
      "deps/add-deps '{:deps {${1:name} {:mvn/version \"${2:version}\"}}}"
    ]
  },
  "bb-cli": {
    "prefix": "bb-cli",
    "body": [
      "babashka.cli"
    ]
  },
  "bb-deps": {
    "prefix": "bb-deps",
