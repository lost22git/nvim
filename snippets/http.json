{
  "get": {
    "prefix": "get",
    "body": [
      "### ${1:GET_DATA}",
      "",
      "${2:GET} ${3:url} HTTP/${4:1.1}",
      "Accept: ${5:application/json}",
      ""
    ]
  },
  "post-json": {
    "prefix": "post-json",
    "body": [
      "### ${1:POST_JSON}",
      "",
      "${2:POST} ${3:url} HTTP/${4:1.1}",
      "Accept: ${5:application/json}",
      "Content-Type: application/json",
      "",
      "{",
      "\t\"${6:key}\": ${7:val}",
      "}",
      ""
    ]
  },
  "post-json-file": {
    "prefix": "post-json-file",
    "body": [
      "### ${1:POST_JSON_FILE}",
      "",
      "${2:POST} ${3:url} HTTP/${4:1.1}",
      "Accept: ${5:application/json}",
      "Content-Type: application/json",
      "",
      "< ${6:./data.json}",
      ""
    ]
  },
  "post-form-data": {
    "prefix": "post-form-data",
    "body": [
      "### ${1:POST_FORMDATA}",
      "",
      "${2:POST} ${3:url} HTTP/${4:1.1}",
      "Accept: ${5:application/json}",
      "Content-Type: application/x-www-form-urlencoded",
      "",
      "${6:k=v}&",
      "${7:k2=v2}",
      ""
    ]
  },
  "post-multipart": {
    "prefix": "post-multipart",
    "body": [
      "### ${1:POST_MULTIPART}",
      "",
      "${2:POST} ${3:url} HTTP/${4:1.1}",
      "Accept: ${5:application/json}",
      "Content-Type: multipart/form-data; boundary=----WebKitFormBoundary{{\\$timestamp}}; charset=utf-8",
      "",
      "------WebKitFormBoundary{{\\$timestamp}}",
      "Content-Disposition: form-data; name=\"${6:image}\"; filename=\"${7:image.png}\"",
      "Content-Type: ${8:image/png}",
      "",
      "< ${9:./image.png}",
      "",
      "------WebKitFormBoundary{{\\$timestamp}}--",
      ""
    ]
  }
}
