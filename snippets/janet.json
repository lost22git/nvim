  "*module-make-env*": {
    "prefix": "v*module-make-env*",
    "body": ["*module-make-env*"]
  },
  "*module-paths*": {
    "prefix": "v*module-paths*",
    "body": ["*module-paths*"]
  },
  "*out*": {
    "prefix": "v*out*",
    "body": ["*out*"]
  },
  "*peg-grammar*": {
    "prefix": "v*peg-grammar*",
    "body": ["*peg-grammar*"]
  },
  "*pretty-format*": {
    "prefix": "v*pretty-format*",
    "body": ["*pretty-format*"]
  },
  "*profilepath*": {
    "prefix": "v*profilepath*",
    "body": ["*profilepath*"]
  },
  "*redef*": {
    "prefix": "v*redef*",
    "body": ["*redef*"]
  },
  "*repl-prompt*": {
    "prefix": "v*repl-prompt*",
    "body": ["*repl-prompt*"]
  },
  "*syspath*": {
    "prefix": "v*syspath*",
    "body": ["*syspath*"]
  },
  "*task-id*": {
    "prefix": "v*task-id*",
    "body": ["*task-id*"]
  },
  "defer": {
    "prefix": "defer",
    "body": ["(defer ${1:finally} ${2:body})"]
  },
  "for-range": {
    "prefix": "for-range",
    "body": ["(for ${1:i} ${2:start} ${3:stop} ${4:body})"]
  },
  "if-with": {
    "prefix": "if-with",
    "body": ["(if-with [${1:bindings}] ${2:body})"]
  },
  "loop-down": {
    "prefix": "loop-down",
    "body": ["(loop [${1:i} :down [${2:start} ${3:stop}]] ${4:body})"]
  },
  "loop-down-to": {
    "prefix": "loop-down-to",
    "body": ["(loop [${1:i} :down-to [${2:start} ${3:stop}]] ${4:body})"]
  },
  "loop-keys": {
    "prefix": "loop-keys",
    "body": ["(loop [${1:k} :keys ${2:col}] ${3:body})"]
  },
  "loop-in": {
    "prefix": "loop-in",
    "body": ["(loop [${1:v} :in ${2:col}] ${3:body})"]
  },
  "loop-pairs": {
    "prefix": "loop-pairs",
    "body": ["(loop [[${1:k} ${2:v}] :pairs ${3:col}] ${4:body})"]
  },
  "loop-range": {
    "prefix": "loop-range",
    "body": ["(loop [${1:i} :range [${2:start} ${3:stop}]] ${4:body})"]
  },
  "loop-range-to": {
    "prefix": "loop-range-to",
    "body": ["(loop [${1:i} :range-to [${2:start} ${3:stop}]] ${4:body})"]
  },
  "try": {
    "prefix": "try",
    "body": ["(try ${1:body} ([e] eprint e))"]
  },
  "when-with": {
    "prefix": "when-with",
    "body": ["(when-with [${1:bindings}] ${2:body})"]
  },
  "with": {
    "prefix": "with",
    "body": ["(with [${1:bindings}] ${2:body})"]
  },
  "with-dyns": {
    "prefix": "with-dyns",
    "body": ["(with-dyns [${1:bindings}] ${2:body})"]
  },
  "with-syms": {
    "prefix": "with-syms",
    "body": ["(with-syms [${1:bindings}] ${2:body})"]
  }
}
