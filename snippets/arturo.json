{
  "execute": {
    "prefix": "execute",
    "body": "${1:executeOuput}: execute \"${2:ls -l}\""
  },
  "execute-args": {
    "prefix": "execute-args",
    "body": "e${1:executeOuput}: execute.args: ${2:[\"-l\"]} \"${3:ls}\""
  },
  "execute-code": {
    "prefix": "execute-code",
    "body": "${1:executeResult}: execute.code \"${2:ls -l}\""
  },
  "execute-inherit": {
    "prefix": "execute-inherit",
    "body": "execute.directly \"${1:ls -l}\""
  },
  "fn": {
    "prefix": "fn",
    "body": [
      "${1:fn-name}: \\$[${2:x}] [",
      "\t$3",
      "]"
    ]
  },
  "if-else": {
    "prefix": "if",
    "body": [
      "if? ${1:1=1} [",
      "\t$2",
      "]",
      "else [",
      "\t$3",
      "]"
    ]
  },
  "if-elseif-else": {
    "prefix": "if-elseif-else",
    "body": [
      "if? ${1:1=1} [",
      "\t$2",
      "]",
      "else if? ${3:1!=1} [",
      "\t$4",
      "]",
      "else [",
      "\t$5",
      "]"
    ]
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop ${1:xs} 'x [",
      "\t$2",
      "]"
    ]
  },
  "loop-forever": {
    "prefix": "loop-forever",
    "body": [
      "loop.forever [",
      "\t$1",
      "]"
    ]
  },
  "loop-kvs": {
    "prefix": "loop-kvs",
    "body": [
      "loop ${1:kvs} [k v] [",
      "\t$2",
      "]"
    ]
  },
  "loop-range": {
    "prefix": "loop-range",
    "body": [
      "loop ${1:from}..${2:to} 'x [",
      "\t$3",
      "]"
    ]
  },
  "loop-range-step": {
    "prefix": "loop-range-step",
    "body": [
      "loop ${1:from}..${2:to} .step: ${3:1} 'x [",
      "\t$4",
      "]"
    ]
  },
  "loop-with-index": {
    "prefix": "loop-with-index",
    "body": [
      "loop.with: 'i ${1:xs} 'x [",
      "\t$2",
      "]"
    ]
  },
  "p": {
    "prefix": "p",
    "body": "print \"$1\""
  },
  "pp": {
    "prefix": "pp",
    "body": "inspect $1"
  },
  "read": {
    "prefix": "read",
    "body": "read \"${1:source}\""
  },
  "read-json": {
    "prefix": "read-json",
    "body": "read.json \"${1:source}\""
  },
  "read-lines": {
    "prefix": "read-lines",
    "body": "read.lines \"${1:source}\""
  },
  "to": {
    "prefix": "to",
    "body": "to :${1:type} ${2:value}"
  },
  "write": {
    "prefix": "write",
    "body": "write \"${1:file}\" \"${2:content}\""
  },
  "write-json": {
    "prefix": "write-json",
    "body": "write.json ${1:null} $2"
  }
}
