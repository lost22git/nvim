    "body": ["*lint-error*"]
  },
  "*lint-levels*": {
    "prefix": "v*lint-levels*",
    "body": ["*lint-levels*"]
  },
  "*lint-warn*": {
    "prefix": "v*lint-warn*",
    "body": ["*lint-warn*"]
  },
  "*macro-form*": {
    "prefix": "v*macro-form*",
    "body": ["*macro-form*"]
  },
  "*macro-lints*": {
    "prefix": "v*macro-lints*",
    "body": ["*macro-lints*"]
  },
  "*module-cache*": {
    "prefix": "v*module-cache*",
    "body": ["*module-cache*"]
  },
  "*module-loaders*": {
    "prefix": "v*module-loaders*",
    "body": ["*module-loaders*"]
  },
  "*module-loading*": {
    "prefix": "v*module-loading*",
    "body": ["*module-loading*"]
