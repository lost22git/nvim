{
  "deriving": {
    "prefix": "deriving",
    "body": [
      "[@@deriving $1]"
    ]
  },
  "Logs-setup": {
    "prefix": "Logs-setup",
    "body": [
      "let setup_logs () = ",
      "\tLogs.set_reporter @@ Logs_fmt.reporter ();",
      "\tLogs.set_level @@ Some Logs.Info"
    ]
  },
  "Logs": {
    "prefix": "Logs",
    "body": [
      "Logs.${1:info} (fun m -> m \"$2\")"
    ]
  }
}
