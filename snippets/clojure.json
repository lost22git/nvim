    ]
  },
  "bb-main": {
    "prefix": "bb-main",
    "body": [
      "(defn -main [args]",
      "\t${1})",
      "",
      "(when (= *file* (System/getProperty \"babashka.file\"))",
      "\t(-main *command-line-args*))"
    ]
  },
  "bb-proc": {
    "prefix": "bb-proc",
    "body": [
      "babashka.process"
    ]
