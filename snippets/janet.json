  "*module-loaders*": {
    "prefix": "v*module-loaders*",
    "body": [
      "*module-loaders*"
    ]
  },
  "*module-loading*": {
    "prefix": "v*module-loading*",
    "body": [
      "*module-loading*"
    ]
  },
  "*module-make-env*": {
    "prefix": "v*module-make-env*",
    "body": [
