{
  "default": {
    "prefix": "default",
    "body": ["_default:", "\t@just --list --unsorted"]
  },
  "exe-info": {
    "prefix": "exe-info",
    "body": [
      "exe-info executable:",
      "\tls -l {{ executable }}",
      "\tfile {{ executable }}",
      "\tldd {{ executable }}"
    ]
  },
  "set-windows-powershell": {
    "prefix": "set-windows-powershell",
    "body": [
      "set windows-shell := [\"powershell\", \"-nologo\", \"-noprofile\", \"-c\"]"
    ]
  },
  "set-windows-pwsh": {
    "prefix": "set-windows-pwsh",
    "body": [
      "set windows-shell := [\"pwsh\", \"-nologo\", \"-noprofile\", \"-c\"]"
    ]
  },
  "set-windows-cmd": {
    "prefix": "set-windows-cmd",
    "body": ["set windows-shell := [\"cmd\", \"/c\"]"]
  }
}
