{
  "codeLens": {
    "enable": true
  },
  "completion": {
    "callSnippet": "Replace"
  },
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "lua/?.lua",
      "lua/?/init.lua",
      "?/lua/?.lua",
      "?/lua/?/init.lua"
    ]
  },
  "telemetry": {
    "enable": false
  },
  "workspace": {
    "library": ["$VIMRUNTIME", "$HOME/.local/share/nvim/lazy"],
    "ignoreGlobs": ["**/*_spec.lua"]
  }
}
